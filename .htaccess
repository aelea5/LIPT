# DreamHost shared hosting — basic hardening
Options -Indexes

# Block sensitive files from direct HTTP access
<FilesMatch "^(\.env|\.env\.example)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Cache headers
<IfModule mod_headers.c>
    <FilesMatch "\.(html?|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    <FilesMatch "\.(gif|jpe?g|png|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    # Block direct access to includes (one-time create_admin.php is allowed)
    RewriteCond %{REQUEST_URI} !create_admin\.php$ [NC]
    RewriteRule ^includes/ - [F,L]
    # Block SQL dumps and env from URL paths
    RewriteRule ^database/ - [F,L]

    # Clean URLs (301 permanent redirects; leading / avoids DreamHost path doubling)
    RewriteRule ^login/?$ /login.php [R=301,L,NC]
    RewriteRule ^schedule/?$ /roster.php [R=301,L,NC]
    RewriteRule ^suggestions/?$ /suggestions.php [R=301,L,NC]
    RewriteRule ^spotlight/?$ /nonprofit.php [R=301,L,NC]
    RewriteRule ^about/?$ /about.php [R=301,L,NC]
    RewriteRule ^menu-ideas/?$ /menu-ideas.php [R=301,L,NC]
    RewriteRule ^dashboard/?$ /dashboard/index.php [R=301,L,NC]
</IfModule>
